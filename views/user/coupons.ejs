<%-include('header')-%>

<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
  integrity="sha512-REPLACE_WITH_YOUR_INTEGRITY_CHECK"
  crossorigin="anonymous"
/>
<div id="page-content">
<section style="background-color: #000000">
  <div class="container py-5">
    <div class="row">
      <div class="col-lg-4">
        <div class="card mb-4">
          <div class="card-body text-center">
            <img
              src="https://cdn1.iconfinder.com/data/icons/public-company-solid/32/employee_employe_workman_user_profiles_avatar_people_human_persons_icon_1-512.png"
              alt="avatar"
              class="rounded-circle img-fluid"
              style="width: 150px"
            />
            <h5 class="my-3"><%=user.name%></h5>
          </div>
        </div>

        <%-include('sidebar')-%>
      </div>

      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <% if (locals.coupons && locals.coupons.length>0) { %>
            <h1>jnk</h1>
            <% coupons.forEach((coupon) => { %>
            <div class="row">
              <div class="col-sm-3">
                <p class="mb-0"><%= coupon.name %></p>
              </div>
              <div class="col-sm-9">
                <p class="text-muted mb-0"><%= coupon.discountValue %></p>
              </div>
            </div>
            <hr />
            <% }); %> <% }else{%>
            <div class="row">
              <div class="col-sm-3">
                <p class="mb-0">No coupon Available</p>
              </div>
              <hr />
            </div>

            <%} %>

            <div class="row">
              <div class="col-sm-9">
                <p class="text-muted mb-0"></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</div>
<%-include('footer')-%>
